# --- Database (PostgreSQL — local AND production) ---
# The app uses PostgreSQL everywhere to avoid a local/production mismatch.
#
# Production: your Supabase Postgres connection string.
# Local dev:  a Supabase connection string, or a local Postgres instance, e.g.
#             postgresql://postgres:postgres@localhost:5432/vexiq?schema=public
#
# Supabase gives you a string like:
#   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# For serverless platforms, prefer Supabase's pooled (pgBouncer, port 6543) URL
# and add ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# --- Teacher login ---
# Password used for the teacher dashboard. If empty in development the app
# falls back to "teacher1234". Always set a strong value in production.
TEACHER_PASSWORD="teacher1234"

# --- Optional email (Resend) ---
# A report email is sent only when ALL THREE are set: RESEND_API_KEY, FROM_EMAIL,
# and TEACHER_NOTIFICATION_EMAIL (the fixed teacher/admin recipient — the student
# form no longer collects a teacher email). If any is empty, the report is stored
# only and the dashboard shows "Email delivery is not configured."
RESEND_API_KEY=""
FROM_EMAIL=""
TEACHER_NOTIFICATION_EMAIL=""

# --- App URL ---
# Public base URL used to build report links in emails.
# Local: http://localhost:3000   Production: https://your-site.netlify.app
APP_URL="http://localhost:3000"
